{
  "name": "sticky-todo",
  "version": "1.0.0",
  "description": "桌面便签待办工具",
  "main": "electron/main.js",
  "author": "zjk",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.zjk.sticky-todo",
    "productName": "Sticky Todo",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Sticky Todo"
    }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "electron": "^35.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.0",
    "electron-builder": "^25.0.0"
  }
}
